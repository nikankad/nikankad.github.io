---
import BaseLayout from "../components/layout/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
---

<BaseLayout title="404 - Page Not Found" description="The page you're looking for doesn't exist.">
  <Container>
    <div class="error-page">
      <p class="error-code">404</p>
      <h1>Page Not Found</h1>
      <p class="muted-text">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="home-button">Go Home</a>
    </div>
  </Container>
</BaseLayout>

<style>
  .error-page {
    padding: var(--space-8) 0;
    max-width: 28rem;
  }

  .error-code {
    font-family: var(--font-pixel);
    font-size: clamp(4rem, 18vw, 7rem);
    line-height: 1;
    color: var(--accent);
    margin-bottom: var(--space-4);
    text-shadow: 0 0 40px var(--accent-bloom);
  }

  h1 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-3);
  }

  .home-button {
    display: inline-block;
    margin-top: var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.85rem 1.4rem;
    color: var(--bg-color);
    background: var(--accent);
    border: 1px solid var(--accent);
    box-shadow: 0 0 24px var(--accent-bloom);
  }

  .home-button:hover {
    text-shadow: none;
  }
</style>
