---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../components/layout/BaseLayout.astro";
import BaseHero from "../../components/shared/BaseHero.astro";
import Container from "../../components/ui/Container.astro";
import ContentList from "../../components/shared/ContentList.astro";
import { formatDateShort } from "../../utils/date";

const experiences = await getCollection("experience");
const sortedExperiences = experiences.sort(
  (a: CollectionEntry<"experience">, b: CollectionEntry<"experience">) => {
    const orderA = a.data.order ?? Number.POSITIVE_INFINITY;
    const orderB = b.data.order ?? Number.POSITIVE_INFINITY;
    if (orderA !== orderB) return orderA - orderB;
    if (a.data.current && !b.data.current) return -1;
    if (!a.data.current && b.data.current) return 1;
    return b.data.startDate.getTime() - a.data.startDate.getTime();
  }
);
---

<BaseLayout title="Experiences" description="Work, programs, and roles I’ve been part of">
  <Container>
    <BaseHero title="Experiences" description="" />

    <ContentList>
      {
        sortedExperiences.map((exp) => (
          <article>
            <div class="title-row">
              <div class="company-info">
                <img src={exp.data.logo} alt="" class="company-logo" loading="lazy" />
                {exp.data.url ? (
                  <a href={exp.data.url} target="_blank" rel="noopener noreferrer">
                    {exp.data.title}
                  </a>
                ) : (
                  <span>{exp.data.title}</span>
                )}
              </div>
              <time>
                {formatDateShort(exp.data.startDate)} -{" "}
                {exp.data.current ? "Present" : exp.data.endDate ? formatDateShort(exp.data.endDate) : ""}
              </time>
            </div>
            <p class="muted-text">{exp.data.description}</p>
          </article>
        ))
      }
    </ContentList>
  </Container>
</BaseLayout>

<style>
  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    font-size: var(--text-sm);
  }

  .company-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-color);
    font-weight: 500;
  }

  .company-info a {
    color: inherit;
  }

  .company-info a:hover {
    color: var(--accent);
  }

  time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: 0;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .title-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-1);
    }
  }
</style>
