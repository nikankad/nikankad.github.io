---
import { getCollection, getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../components/layout/BaseLayout.astro";
import ContentList from "../components/shared/ContentList.astro";
import Container from "../components/ui/Container.astro";
import GithubContributions from "../components/shared/GithubContributions.astro";
import HeroGlobe from "../components/HeroGlobe";
import { formatDateShort } from "../utils/date";

const siteConfig = await getEntry("site", "home");
if (!siteConfig) {
  throw new Error("Site configuration not found");
}

const site = siteConfig.data;

const githubUrl = site.socialLinks?.find((link) => link.platform === "GitHub")?.url ?? "https://github.com/nikankad";
const githubUsername = githubUrl.replace(/\/+$/, "").split("/").pop() ?? "nikankad";

const experiences = await getCollection("experience");
const sortedExperiences = experiences.sort(
  (a: CollectionEntry<"experience">, b: CollectionEntry<"experience">) => {
    const orderA = a.data.order ?? Number.POSITIVE_INFINITY;
    const orderB = b.data.order ?? Number.POSITIVE_INFINITY;
    if (orderA !== orderB) return orderA - orderB;
    if (a.data.current && !b.data.current) return -1;
    if (!a.data.current && b.data.current) return 1;
    return b.data.startDate.getTime() - a.data.startDate.getTime();
  }
);

const projects = await getCollection("projects");
const featuredProjects = projects
  .filter((project: CollectionEntry<"projects">) => project.data.featured)
  .slice(0, 3);
---

<BaseLayout title={`${site.name} - ${site.title}`} description={site.introduction || `${site.name}, ${site.title}`}>
  <Container>
    <section class="hero" aria-label="Introduction">
      <div class="hero-field" aria-hidden="true">
        <div class="hero-globe">
          <HeroGlobe client:load />
        </div>
        <div class="hero-field-overlay"></div>
        <div class="hero-bloom bloom-pulse"></div>
      </div>

      <div class="hero-copy">
        <img
          src="/images/companies/fish.jpg"
          alt=""
          class="hero-portrait animate-fade stagger-1"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="96"
          height="96"
        />
        <h1 class="hero-brand animate-pixel stagger-2">{site.name}</h1>
        <p class="hero-line animate-slide-up stagger-3">{site.title}</p>
        <p class="hero-support animate-slide-up stagger-4">MSCS @ Northeastern University</p>

        {
          site.socialLinks && (
            <div class="hero-cta animate-slide-up stagger-5">
              {site.socialLinks.map(({ platform, url }) => (
                <a href={url} target="_blank" rel="noopener noreferrer">
                  {platform}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>{site.sections.projects.title}</h2>
        <a href="/projects">{site.sections.projects.viewAllText}</a>
      </div>
      <ContentList>
        {
          featuredProjects.map((project) => (
            <article class="entry">
              <div class="title-row">
                <a href={project.data.url} target="_blank" rel="noopener noreferrer">
                  {project.data.title}
                </a>
              </div>
              <p class="muted-text">{project.data.description}</p>
              {project.data.techs && (
                <div class="tags">
                  {project.data.techs.map((tech) => (
                    <span>{tech}</span>
                  ))}
                </div>
              )}
            </article>
          ))
        }
      </ContentList>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>{site.sections.experience.title}</h2>
        <a href="/experiences">{site.sections.experience.viewAllText}</a>
      </div>
      <div class="content-list">
        {
          sortedExperiences.slice(0, 2).map((exp) => (
            <article class="entry">
              <div class="title-row">
                <div class="company-info">
                  <img src={exp.data.logo} alt="" class="company-logo" />
                  <span>{exp.data.title}</span>
                </div>
                <time>
                  {formatDateShort(exp.data.startDate)} -{" "}
                  {exp.data.current ? "Present" : exp.data.endDate ? formatDateShort(exp.data.endDate) : ""}
                </time>
              </div>
              <p class="muted-text">{exp.data.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section github-section" aria-label="GitHub activity">
      <GithubContributions username={githubUsername} />
    </section>

    <section class="section contact">
      <div class="section-header">
        <h2>Contact</h2>
      </div>
      <p class="muted-text">Open to collaborations, research, and interesting problems.</p>
      <a href="mailto:nikan.nik@gmail.com" class="contact-button">Email Me</a>
    </section>
  </Container>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: min(58vh, 30rem);
    display: grid;
    align-content: end;
    gap: var(--space-5);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
    overflow: hidden;
  }

  .hero-globe {
    position: absolute;
    right: var(--space-4);
    bottom: var(--space-4);
    width: min(52%, 20rem);
    height: min(52%, 20rem);
  }

  .hero-globe :global(canvas) {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  .hero-field {
    position: absolute;
    inset: 0;
    z-index: 0;
    border: 1px solid var(--border-color);
    background-color: #08080a;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-field-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(13, 13, 15, 0.34) 45%,
      rgba(13, 13, 15, 0.92) 100%
    );
    pointer-events: none;
  }

  .hero-bloom {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 55%;
    height: 55%;
    background: radial-gradient(ellipse at center, rgba(52, 166, 255, 0.28), transparent 70%);
    filter: blur(28px);
    pointer-events: none;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    max-width: 28rem;
  }

  .hero-brand {
    margin: 0;
    line-height: 0.95;
    color: var(--text-color);
    text-shadow: 0 0 40px rgba(52, 166, 255, 0.25);
  }

  .hero-line {
    margin: var(--space-4) 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--text-color);
    text-shadow: 0 0 18px rgba(13, 13, 15, 0.8);
  }

  .hero-support {
    margin: var(--space-2) 0 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
    text-shadow: 0 0 18px rgba(13, 13, 15, 0.8);
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    margin-top: var(--space-5);
  }

  .hero-cta a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--text-color);
    border-bottom: 1px solid var(--border-strong);
    padding-bottom: 0.15rem;
  }

  .hero-cta a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .hero-portrait {
    width: 5.5rem;
    height: 5.5rem;
    margin-bottom: var(--space-4);
    object-fit: cover;
    border: 1px solid var(--border-strong);
    border-radius: 0;
    image-rendering: auto;
    filter: none;
    mix-blend-mode: normal;
    opacity: 1;
  }

  .section {
    margin: var(--space-7) 0;
  }

  .hero + .section {
    margin-top: 0;
  }

  .entry {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--border-color);
  }

  .entry:last-child {
    border-bottom: none;
  }

  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    font-size: var(--text-sm);
  }

  .title-row a,
  .title-row span {
    color: var(--text-color);
    font-weight: 500;
  }

  .title-row a:hover {
    color: var(--accent);
  }

  .company-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: 0;
    white-space: nowrap;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.75rem;
    margin-top: var(--space-3);
  }

  .tags span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .contact .muted-text {
    margin-bottom: var(--space-5);
  }

  .contact-button {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0;
    text-transform: uppercase;
    padding: 0.85rem 1.4rem;
    color: var(--bg-color);
    background: var(--accent);
    border: 1px solid var(--accent);
    box-shadow: 0 0 24px var(--accent-bloom);
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-bloom),
      background var(--transition-base);
  }

  .contact-button:hover {
    text-shadow: none;
    transform: translateY(-1px);
    box-shadow: 0 0 36px var(--accent-bloom);
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 24rem;
      padding: var(--space-5) var(--space-4) var(--space-5);
      margin-bottom: var(--space-6);
    }

    .hero-globe {
      right: -10%;
      bottom: -14%;
      width: min(88%, 20rem);
      height: min(78%, 18rem);
    }

    .hero-portrait {
      width: 4.25rem;
      height: 4.25rem;
      margin-bottom: var(--space-3);
    }

    .title-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-1);
    }
  }
</style>
