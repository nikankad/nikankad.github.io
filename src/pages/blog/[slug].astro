---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../components/layout/BaseLayout.astro";
import { formatDate } from "../../utils/date";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} includeKatex={true}>
  <article class="post">
    <header>
      <h1>{post.data.title}</h1>
      <time datetime={post.data.publishedAt.toISOString()}>
        {formatDate(post.data.publishedAt)}
      </time>
      {
        post.data.tags && (
          <div class="tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )
      }
    </header>
    <div class="content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  article.post {
    margin-top: var(--space-4);
  }

  article.post header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--border-color);
  }

  article.post h1 {
    margin-bottom: var(--space-3);
    font-size: clamp(1.75rem, 5vw, var(--text-4xl));
  }

  article.post time {
    font-family: var(--font-mono);
    color: var(--text-tertiary);
    font-size: var(--text-xs);
    letter-spacing: 0;
    text-transform: uppercase;
  }

  article.post .tags {
    margin-top: var(--space-3);
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  article.post .tag {
    display: inline-block;
    padding: 0.2rem 0.45rem;
    border: 1px solid var(--border-color);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  article.post .content {
    line-height: 1.75;
  }

  article.post .content :global(h2),
  article.post .content :global(h3) {
    margin-top: var(--space-7);
    margin-bottom: var(--space-3);
  }

  article.post .content :global(p) {
    margin-bottom: 1.25rem;
    max-width: 100%;
  }

  article.post .content :global(img) {
    border-radius: 0;
    border: 1px solid var(--border-color);
    margin: var(--space-5) 0;
  }

  article.post .content :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: var(--space-4);
    margin: var(--space-5) 0;
    color: var(--text-muted);
  }

  article.post .content :global(pre) {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--bg-color-muted);
    border: 1px solid var(--border-color);
    overflow-x: auto;
    margin: var(--space-5) 0;
  }

  article.post .content :global(code) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  article.post .content :global(a) {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  article.post .content :global(ul),
  article.post .content :global(ol) {
    margin: var(--space-4) 0;
    padding-left: var(--space-5);
  }

  article.post .content :global(li) {
    margin: var(--space-2) 0;
  }
</style>
