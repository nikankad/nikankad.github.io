---
interface Props {
  categories: string[];
  currentPath: string;
  plural?: boolean;
  basePath: string;
}

const { categories, currentPath, plural, basePath } = Astro.props;
---

<div class="categories">
  <a href={`/${basePath}`} class:list={["category-link", { active: currentPath === `/${basePath}` }]}>All</a>
  {
    categories.map((category) => (
      <a
        href={`/${basePath}/${category}`}
        class:list={["category-link", { active: currentPath === `/${basePath}/${category}` }]}
      >
        {category + (plural ? "s" : "")}
      </a>
    ))
  }
</div>

<style>
  .categories {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .category-link {
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid var(--border-color);
    padding: 0.35rem 0.7rem;
    border-radius: 0;
    text-decoration: none;
    transition:
      background var(--transition-base),
      color var(--transition-base),
      border-color var(--transition-base);
  }

  .category-link:hover,
  .category-link.active {
    background: var(--accent-soft);
    border-color: var(--accent);
    color: var(--text-color);
    text-shadow: none;
  }
</style>
