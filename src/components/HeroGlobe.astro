---
/**
 * Decorative dot-globe rendered with dot-globe's framework-free embed
 * (window.DotGlobe.create) instead of a React island, and loaded lazily on
 * idle so the ~260 KB (gzip) three.js bundle never blocks first paint.
 * The vendored bundle lives at public/vendor/dot-globe.js (auto-init stripped).
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["hero-globe-mount", className]} data-hero-globe></div>

<style>
  .hero-globe-mount {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  const DOT_GLOBE_SRC = "/vendor/dot-globe.js?v=1.5.3";

  const OPTIONS = {
    radius: 12,
    cameraDistance: 30,
    tilt: [34, -18] as [number, number],
    rotationSpeed: 0.0009,
    chars: "*",
    atmosphere: true,
    atmosphereOpacity: 0.2,
    backgroundOpacity: 0,
    backgroundColor: 0x0d0d0f,
  };

  let loader: Promise<void> | null = null;
  function loadDotGlobe(): Promise<void> {
    if ((window as any).DotGlobe) return Promise.resolve();
    if (loader) return loader;
    loader = new Promise((resolve, reject) => {
      const s = document.createElement("script");
      s.src = DOT_GLOBE_SRC;
      s.async = true;
      s.onload = () => resolve();
      s.onerror = () => reject(new Error("dot-globe failed to load"));
      document.head.appendChild(s);
    });
    return loader;
  }

  function mountAll() {
    const mounts = document.querySelectorAll<HTMLElement>("[data-hero-globe]");
    if (!mounts.length) return;
    loadDotGlobe()
      .then(() => {
        const api = (window as any).DotGlobe;
        const create = api?.createDotGlobe ?? api?.create;
        if (typeof create !== "function") return;
        mounts.forEach((el) => {
          if (el.dataset.globeMounted) return;
          el.dataset.globeMounted = "1";
          create({ container: el, ...OPTIONS });
        });
      })
      .catch(() => {
        /* decorative only — silently skip if it can't load */
      });
  }

  if ("requestIdleCallback" in window) {
    (window as any).requestIdleCallback(mountAll, { timeout: 2500 });
  } else {
    setTimeout(mountAll, 300);
  }
</script>
